# ============================================================
# API ID  : AGENT-CHAT-API-002
# 기능명  : 채팅 히스토리 조회
# Method  : GET
# Endpoint: /api/chat/{repo_id}/history
# Auth    : 필요
# 관련 기능 ID: AGENT-CHAT-B-201
# 상태    : 시작 전
# ============================================================

@baseUrl = http://localhost:8000
@accessToken = replace-me
@repo_id = replace-me-repo_id

### 정상 요청
GET {{baseUrl}}/api/chat/{{repo_id}}/history?page=1&limit=20
Authorization: Bearer {{accessToken}}

# Success Response: 200 OK
# {
#   "code": 200,
#   "message": "success",
#   "data": {
#     "totalCount": 12,
#     "chats": [{"sessionId": "...", "question": "...", "answer": "...", "toolCallCount": 2, "elapsedSeconds": 6.3, "createdAt": "2026-06-18T10:10:00Z"}]
#   }
# }


### 에러 케이스 - 인증 없음
GET {{baseUrl}}/api/chat/{{repo_id}}/history

# Error Response: 401 Unauthorized
# { "code": "UNAUTHORIZED", "message": "인증이 필요합니다." }