# =============================================================================
# RepoInsight 环境变量示例
# 复制此文件为 .env 并填入真实密钥。
# =============================================================================

# ---- LLM Provider（选择其中一组，其他用 # 注释掉）------------------------

# [方案 A] OpenAI GPT-5.4 家族（最高质量，国内需代理）
OPENAI_API_KEY=sk-proj-xxx
OPENAI_MODEL=gpt-5.4
OPENAI_BASE_URL=https://api.openai.com/v1

# [方案 B] DeepSeek V3.2（国内直连，$0.28/$0.42 per 1M tokens，超高性价比）
# OPENAI_API_KEY=sk-deepseek-xxx
# OPENAI_MODEL=deepseek-chat
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# [方案 C] 通义千问 Qwen3（阿里云百炼 OpenAI 兼容模式）
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=qwen3-max                   # 或 qwen3.5-plus / qwen3.5-flash
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 海外可用： https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# [方案 D] 智谱 GLM-5 / GLM-4.6（国内直连）
# OPENAI_API_KEY=xxx.xxx
# OPENAI_MODEL=glm-5                        # 或 glm-4.6 / glm-4.5
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# [方案 E] Moonshot Kimi K2.5（国内直连，262K 长上下文）
# OPENAI_API_KEY=sk-xxx
# OPENAI_MODEL=kimi-k2.5                    # 或 kimi-k2 / moonshot-v1-128k
# OPENAI_BASE_URL=https://api.moonshot.cn/v1

# ---- LLM 超时与重试 ---------------------------------------------------------
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2

# ---- 后端 --------------------------------------------------------------------
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8770
LOG_LEVEL=INFO

# ---- Pipeline 超时 ----------------------------------------------------------
ANALYSIS_TOTAL_TIMEOUT_SECONDS=120
COMMUNITY_ASSESSOR_TIMEOUT_SECONDS=45
STATIC_ANALYZER_TIMEOUT_SECONDS=60
BEHAVIOR_INFERER_TIMEOUT_SECONDS=40

# ---- 仓库克隆 ----------------------------------------------------------------
GITHUB_CLONE_DEPTH=50
TMP_REPO_DIR=./tmp_repos
CACHE_TTL_HOURS=24

# ---- SQLite 数据库 ----------------------------------------------------------
DATABASE_URL=sqlite:///./audit.db

# ---- 前端 --------------------------------------------------------------------
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://127.0.0.1:8770
VITE_WS_URL=ws://127.0.0.1:8770/ws

# ---- 可选（GitHub API 加速 BehaviorInferer 读 PR 标题）---------------------
# GITHUB_TOKEN=ghp_xxx
