PORT=4000

# PostgreSQL — used by docker-compose.yml; change these before running docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-before-running
POSTGRES_DB=mono_repo_auth
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=generate-a-random-secret-with-the-command-above
BETTER_AUTH_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000

# AI Analysis — get your key at console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# GitHub OAuth — create at github.com/settings/developers
# Callback URL: http://localhost:4000/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
